pipeline {
    agent any

    stages {

        stage('Clone') {
            steps {
                git url: 'https://github.com/Maaz-ismail-md/my-python-appp.git', branch: 'master'
            }
        }

        stage('Run Script') {
            steps {
                sh 'chmod +x script.sh'
                sh './script.sh'
            }
        }

        stage('Run Python File') {
            steps {
                sh 'python3 app.py'
            }
        }

    }
}
